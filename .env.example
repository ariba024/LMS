# Arresto LMS — environment configuration template
# Copy this file to .env and fill in your values.
# Restart the server after changing any value.

# ── Database ──────────────────────────────────────────────────────────────────
# Default: local PostgreSQL (start with: docker-compose up -d postgres)
# Production: point to your RDS instance
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arresto_lms

# ── Claude / Anthropic (required for /chat and /courses/generate) ─────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MODEL=claude-sonnet-4-6

# ── OCR for scanned PDFs ──────────────────────────────────────────────────────
ENABLE_OCR=false

# ── Image captioning (BLIP-2, very slow on CPU) ───────────────────────────────
ENABLE_CAPTIONING=false

# ── Storage paths ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
CHROMA_DB_DIR=./chroma_db
CHROMA_DB_DIR_BGE=./chroma_db_bge_comparison

# AWS production: point these to an EFS mount path, e.g.:
# UPLOAD_DIR=/data/uploads
# CHROMA_DB_DIR=/data/chroma_db
# CHROMA_DB_DIR_BGE=/data/chroma_db_bge

# ── Progress tracker ──────────────────────────────────────────────────────────
# Local dev: lms.db (SQLite, created automatically)
# AWS production: use an EFS-mounted path for persistence across container restarts
PROGRESS_DB_PATH=lms.db
# PROGRESS_DB_PATH=/data/progress.db

# ── Focus detection ───────────────────────────────────────────────────────────
# WebSocket URL compiled into Flutter at build time via --dart-define=FOCUS_WS_URL
# Served by the main LMS backend — same host, same port, /ws/detect path.
# Local dev: ws://localhost:8000/ws/detect
# AWS production: derived automatically by deploy.sh (wss://yourdomain.com/ws/detect)
FOCUS_WS_URL=ws://localhost:8000/ws/detect

# ── CORS ─────────────────────────────────────────────────────────────────────
# Dev: "*"  |  Prod: "https://yourdomain.com" (comma-separate multiple origins)
CORS_ORIGINS=*

# ── Video rendering ───────────────────────────────────────────────────────────
TTS_PROVIDER=auto

# ── Sarvam AI (Indian-language TTS + STT) ────────────────────────────────────
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_LANGUAGE=en-IN

# ── HeyGen (premium avatar videos, optional) ─────────────────────────────────
HEYGEN_API_KEY=
